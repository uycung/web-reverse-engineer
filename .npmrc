# Netlify builds with pnpm need key packages hoisted to the root node_modules
# so the OpenNext/Next.js runtime plugin can resolve them.
# Alternative: set PNPM_FLAGS=--shamefully-hoist in the Netlify dashboard.
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*tailwindcss*
public-hoist-pattern[]=*postcss*
